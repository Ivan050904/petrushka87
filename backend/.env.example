DATABASE_URL=sqlite:///./storage/folio_one.db
ENVIRONMENT=local
SECRET_KEY=generate-long-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REGISTRATION_ENABLED=false
TRUST_PROXY_HEADERS=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
AI_PROVIDER=openai-compatible
AI_CLASSIFICATION_ENABLED=false
USER_TIMEZONE=Asia/Vladivostok
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
OPENAI_COMPATIBLE_API_KEY=ollama
OPENAI_COMPATIBLE_MODEL=qwen2.5-coder:7b
DIGEST_ENABLED=true
DIGEST_TOPICS=ии агенты,cursor ai,claude codex,claude агент,cursor ide
DIGEST_MAX_ARTICLES=5
DIGEST_SCHEDULE_HOUR=8
DIGEST_USER_EMAIL=petr@petr.local
DIGEST_LLM_BASE_URL=http://localhost:11434/v1
DIGEST_LLM_API_KEY=ollama
DIGEST_LLM_MODEL=qwen2.5-coder:7b
DIGEST_SEARCH_PROVIDER=habr
DIGEST_FIRST_RUN_LOOKBACK_DAYS=7
DIGEST_SCHEDULER_ENABLED=true
AI_DIGEST_TUNED_QUERIES_MAX_AGE_DAYS=7
AI_DIGEST_TUNE_MIN_FEEDBACK=3

PSYCH_DIGEST_ENABLED=true
PSYCH_DIGEST_MAX_ARTICLES=3
PSYCH_DIGEST_LLM_MODEL=openai/gpt-4o
PSYCH_DIGEST_LLM_API_KEY=
PSYCH_DIGEST_USE_LLM_FILTER=false
# PSYCH_DIGEST_QUERIES=  # optional override; default = built-in 3 blocks
YANDEX_AI_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_CLOUD_FOLDER_ID=
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_MODEL=aliceai-llm-flash/latest
NOTES_AI_ENABLED=true
NOTES_AI_PROVIDER=auto
NOTES_AI_BASE_URL=
NOTES_AI_API_KEY=
NOTES_AI_MODEL=
FINANCE_AI_ENABLED=true
FINANCE_AI_BASE_URL=
FINANCE_AI_API_KEY=
FINANCE_AI_MODEL=
ASSISTANT_ENABLED=false
ASSISTANT_BASE_URL=https://models.github.ai/inference
ASSISTANT_API_KEY=
ASSISTANT_MODEL=openai/gpt-4o-mini
ASSISTANT_AUTO_CONFIRM=false
ASSISTANT_MAX_HISTORY=20
CONTEXT_CANDIDATE_LIMIT=1500
CONTEXT_SNIPPET_LIMIT=40
CONTEXT_MAX_CHARS=24000
CONTEXT_DATE_LOOKUP_ENABLED=true
CONTEXT_DEBUG=false
CONTEXT_ROUTER_MULTI_SCOPE=true
CONTEXT_EMBEDDINGS_ENABLED=true
CONTEXT_EMBEDDINGS_PROVIDER=hash
CONTEXT_EMBEDDINGS_MODEL=text-embedding-3-small
CONTEXT_EMBEDDINGS_API_KEY=
CONTEXT_EMBEDDINGS_BASE_URL=

THERAPY_SESSIONS_ENABLED=true
THERAPY_MAX_UPLOAD_BYTES=524288000
THERAPY_LLM_PROVIDER=auto
THERAPY_LLM_MODEL=openai/gpt-4o
THERAPY_LLM_API_KEY=
THERAPY_LLM_BASE_URL=
THERAPY_WHISPER_MODEL=small
THERAPY_WHISPER_DEVICE=cpu
THERAPY_WHISPER_COMPUTE_TYPE=int8
THERAPY_DIARIZATION_ENABLED=true
THERAPY_NUM_SPEAKERS=2
HF_TOKEN=
SPEECH_ENABLED=true
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
SPEECH_LANGUAGE=ru
SPEECH_MAX_BYTES=26214400
FILE_STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage/files
S3_BUCKET_NAME=
S3_PREFIX=
S3_ENDPOINT_URL=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Транскрибация YouTube (GitHub Models или OpenAI)
TRANSCRIPTION_URL_PREFIX=/transcription
TRANSCRIPTION_DATA_DIR=./storage/transcription
# auto: github_pat -> GitHub Models, sk- -> OpenAI
TRANSCRIPTION_LLM_PROVIDER=
TRANSCRIPTION_LLM_BASE_URL=
TRANSCRIPTION_LLM_MODEL=

# YouTube / yt-dlp: cookies помогают обойти «Sign in to confirm you're not a bot»
# auto — edge/firefox/chrome на Windows (chrome последним: блокируется, пока браузер открыт)
YTDLP_COOKIES_FROM_BROWSER=auto
# Файл cookies (Netscape). По умолчанию также ищется storage/youtube-cookies.txt
YTDLP_COOKIES_FILE=
